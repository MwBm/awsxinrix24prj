{
  "manifest_version": 3,
  "name": "AskRON",
  "version": "1.0",
  "description": "AskRon - A Chrome extension that interacts with a Flask server to assist users in navigating webpages. Made for INRIX Hackathon 2024.",
  "permissions": ["activeTab", "tabs", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon2.png",
    "48": "icons/icon3.png",
    "128": "icons/icon4.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon2.png",
      "48": "icons/icon3.png",
      "128": "icons/icon4.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
  
}
